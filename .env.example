# Copia este archivo a .env y pega los valores de tu proyecto Supabase
# (Dashboard → Settings → API)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU-ANON-KEY

# Notificaciones push (genera el par con: npx web-push generate-vapid-keys)
# La pública se embebe en el build del cliente; la privada NUNCA va aquí:
# solo como variable de entorno en Vercel (junto con VAPID_SUBJECT,
# SUPABASE_SERVICE_ROLE_KEY y NOTIFY_SECRET — ver README).
VITE_VAPID_PUBLIC_KEY=TU-VAPID-PUBLIC-KEY
